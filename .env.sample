# Example environment for Collect_metrics/collect.py
# Copy to .env and adjust as needed.

# Databend configuration
HOST=localhost
DATABEND_PORT=8000
PROMETHEUS_PORT=9091

# PostgreSQL configuration (for --postgres flag)
PG_HOST=              # Leave empty for local peer auth
PG_PORT=5432
PG_USER=              # Leave empty to use current Unix user
PG_PASSWORD=          # Leave empty for peer auth
PG_DATABASE=tpcds1g   # Default database for metrics collection

# DuckDB configuration (for --duckdb flag)
DUCKDB_PATH=./tpcds1g.duckdb

# Comma-separated lists; lengths should match
LP_QUERY_SET=llm
LP_DATABASE=llm
# Seconds to wait after each query batch
WAIT_TIME=0
